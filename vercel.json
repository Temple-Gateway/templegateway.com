{
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap.xml"
        },
        {
            "source": "/robots.txt",
            "destination": "/api/robots.txt"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}